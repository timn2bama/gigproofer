# Database
DATABASE_URL='postgresql://USER:PASSWORD@HOST:PORT/DATABASE?connect_timeout=15'

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# AWS / S3
AWS_PROFILE=your-aws-profile
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_FOLDER_PREFIX=your-folder-prefix/

# AbacusAI / LLM
ABACUSAI_API_KEY=your-abacusai-api-key

# Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key

# App / Notifications
WEB_APP_ID=your-web-app-id
NOTIF_ID_NEW_USER_SIGNUP=your-notification-id
NOTIF_ID_NEW_PURCHASE=your-notification-id
NOTIF_ID_FUNDED_LOAN_COMMISSION=your-notification-id
